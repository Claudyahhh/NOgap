# Personal data (user fills these)
cv.md
data/applications.md
data/gap-backlog.md
JDlist/*.md
!JDlist/.gitkeep
brief/*.md
!brief/.gitkeep
cv-tailor/*.md
!cv-tailor/.gitkeep
gap-roadmap/*.md
!gap-roadmap/.gitkeep
interview-prep/*.md
!interview-prep/.gitkeep
interview-strategy/*.md
!interview-strategy/.gitkeep
interview-review/*.md
!interview-review/.gitkeep
archive/
output/*
!output/.gitkeep

# Writing samples (user's personal files — never committed)
writing-samples/*
!writing-samples/README.md

# User config and customization (never auto-updated)
config/profile.yml
modes/_profile.md

# Secrets
.env

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# OS
.DS_Store
*.mov
*.mp4
.obsidian/

# Claude Code local
.claude/settings.local.json
.claude/memory/
package-lock.json
